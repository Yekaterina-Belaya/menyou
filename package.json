{
  "name": "menyou-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:ru": "ng serve --configuration=ru",
    "start:en": "ng serve --configuration=en",
    "build": "ng build",
    "build:ru": "ng build --configuration=ru",
    "extract-i18n": "ng extract-i18n --output-path src/locale",
    "init-i18n": "copy src\\locale\\messages.xlf src\\locale\\messages.ru.xlf && copy src\\locale\\messages.xlf src\\locale\\messages.en.xlf",
    "i18n": "npm run extract-i18n && npm run init-i18n",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --no-watch --browsers=ChromeHeadless",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\"",
    "format:write": "prettier --write \"src/**/*.{ts,html,scss,json}\""
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@angular/localize": "^22.0.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  }
}
